# Enables the local-only Ask Rudy API route in development.
# Keep this off in production; the route also refuses to run when NODE_ENV=production.
ASK_RUDY_LOCAL_ENABLED=true

# Shows the Ask Rudy UI in production builds only after a hosted provider exists.
# Keep false/omitted for the local Ollama-only MR.
NEXT_PUBLIC_ASK_RUDY_ENABLED=false

# Provider boundaries. Keep these defaults for the local Ollama lab.
ASK_RUDY_MODEL_PROVIDER=ollama
ASK_RUDY_RETRIEVAL_PROVIDER=local-json

# Production indexing only. Not needed for local Ollama.
# Do not set NEXT_PUBLIC_ASK_RUDY_ENABLED=true until the production API/guardrail MR lands.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
ASK_RUDY_CLOUDFLARE_EMBED_MODEL=@cf/baai/bge-base-en-v1.5
ASK_RUDY_CLOUDFLARE_CHAT_MODEL=@cf/meta/llama-3.2-3b-instruct
ASK_RUDY_MAX_OUTPUT_TOKENS=700
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
ASK_RUDY_UPSTASH_NAMESPACE=ask-rudy

# Production API guardrails. Keep production disabled until the Upstash Vector
# index has been populated and Redis caps/switches are ready.
ASK_RUDY_PROD_ENABLED=false
ASK_RUDY_PROVIDER_CLOUDFLARE_ENABLED=true

# Redis guardrails can use either explicit Upstash Redis names or Vercel KV names.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
ASK_RUDY_DAILY_LIMIT=50
ASK_RUDY_MONTHLY_LIMIT=1000
ASK_RUDY_IP_DAILY_LIMIT=3
ASK_RUDY_IP_HASH_SALT=
